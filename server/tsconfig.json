{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "types": ["node"],
    "typeRoots": ["./node_modules/@types", "./src/types"],

    "sourceMap": true,

    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true
  }
}